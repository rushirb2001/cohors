# Rust
/target
**/target
# Cargo.lock is committed: cohors ships as a binary, so a locked dependency
# graph gives reproducible builds.
*.rs.bk
*.pdb

# WASM / web build output
/crates/cohors-web/dist
/crates/cohors-web/pkg

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# cohors runtime artifacts (in case they ever land in-tree during dev)
/.cohors-cache
*.log

# In-repo binary install (cargo install --root .local), for local testing
/.local

# Demo recording scratch
*.gif.tmp

# Internal material — kept local, never committed or published.
/KICKOFF_PROMPT.md
/CLAUDE.md
/docs/
